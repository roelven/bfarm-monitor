# BfArM Monitor — configuration template
# Copy to .env and fill in your values. Never commit .env.

# Medications to monitor (JSON array, one line)
WATCH_LIST=[{"label":"My Med 10mg","match_wirkstoffe":["active-ingredient"],"match_name":["brand-name"]}]

# Notification method: signal | ntfy | gotify | telegram | smtp
NOTIFY_METHOD=ntfy

# Signal (via signal-cli-rest-api)
# SIGNAL_API_URL=http://host.docker.internal:8080
# SIGNAL_SENDER=+49XXXXXXXXXX
# SIGNAL_RECIPIENTS=["+49XXXXXXXXXX"]

# ntfy
# NTFY_URL=https://ntfy.sh
# NTFY_TOPIC=your-unique-topic-name
# NTFY_TOKEN=

# Gotify
# GOTIFY_URL=http://gotify:80
# GOTIFY_TOKEN=your-app-token

# Telegram
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# TELEGRAM_CHAT_ID=your-chat-id

# SMTP
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user
# SMTP_PASS=pass
# SMTP_FROM=alerts@example.com
# SMTP_TO=you@example.com
